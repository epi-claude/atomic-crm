{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "atomic-crm",
  "main": "./worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "rules": [
    { "type": "Text", "globs": ["**/*.html"], "fallthrough": false }
  ]
}
